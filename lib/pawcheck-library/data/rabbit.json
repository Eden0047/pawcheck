        {"condition": "Pain (from any cause)", "likelihood": "common", "brief": "Rabbits stop eating when in pain"},
        {"condition": "Hairball / trichobezoar", "likelihood": "common", "brief": "Usually a symptom of stasis, not cause"},
        {"condition": "Stress (rehoming, predator scare)", "likelihood": "common", "brief": "Can trigger stasis"},
        {"condition": "Sudden diet change", "likelihood": "common", "brief": "Especially new pellets"},
        {"condition": "Bloat / gut blockage", "likelihood": "occasional but critical", "brief": "Hard distended abdomen - emergency"},
        {"condition": "Underlying illness", "likelihood": "common", "brief": "Stasis is often secondary to other problem"}
      ],
      "home_care": [
        "NOT EATING FOR 12+ HOURS = EMERGENCY VET",
        "Offer favourite fresh herbs (coriander, basil, dill) and leafy greens",
        "Keep rabbit warm",
        "Monitor for any droppings produced",
        "Encourage water intake (syringe water if needed, gently)",
        "Gentle abdominal massage MAY help if approved by vet",
        "Do NOT force-feed without vet guidance - aspiration risk"
      ],
      "vet_urgency": {
        "low": "(no low - any rabbit not eating needs prompt vet)",
